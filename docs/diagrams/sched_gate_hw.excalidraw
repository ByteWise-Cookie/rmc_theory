    {"type":"text","id":"regbox_h","x":58,"y":134,"width":330,"height":22,"text":"SCOREBOARD — registered state (FFs)","originalText":"SCOREBOARD — registered state (FFs)","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":300012,"version":1,"versionNonce":300013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.25},
    {"type":"text","id":"regbox_b","x":58,"y":170,"width":330,"height":360,"text":"per-bank timing:\n  next_cas[b]  next_act[b]  next_pre[b]\n  row_open[b]  open_row[b]\n\nglobal / cross-bank:\n  dqFree           DQ busy until\n  next_cas_any     tCCD_S (any BG)\n  next_cas_bg[bg]  tCCD_L (same BG)\n  next_act spacing tRRD_L / tRRD_S\n  tFAW ring        < 4 ACT / window\n  turnaround win   tRTW / tWTR\n\narbiter:\n  age[lane]        PRE / ACT / CAS\n\ngc  — free-running counter","originalText":"per-bank timing:\n  next_cas[b]  next_act[b]  next_pre[b]\n  row_open[b]  open_row[b]\n\nglobal / cross-bank:\n  dqFree           DQ busy until\n  next_cas_any     tCCD_S (any BG)\n  next_cas_bg[bg]  tCCD_L (same BG)\n  next_act spacing tRRD_L / tRRD_S\n  tFAW ring        < 4 ACT / window\n  turnaround win   tRTW / tWTR\n\narbiter:\n  age[lane]        PRE / ACT / CAS\n\ngc  — free-running counter","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":300014,"version":1,"versionNonce":300015,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.35},


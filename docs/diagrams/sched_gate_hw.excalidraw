    {"type":"text","id":"arbiter_t","x":1104,"y":280,"width":222,"height":130,"text":"WEIGHT ARBITER\n\npriority encoder\nCAS > ACT > PRE\n+ aging\nargmax(K·control+age)\n\n1 winner / cycle","originalText":"WEIGHT ARBITER\n\npriority encoder\nCAS > ACT > PRE\n+ aging\nargmax(K·control+age)\n\n1 winner / cycle","fontSize":14,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400003,"version":1,"versionNonce":400004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"arbiter","lineHeight":1.3},


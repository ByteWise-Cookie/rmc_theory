    {"type":"text","id":"caveat_t","x":552,"y":810,"width":486,"height":48,"text":"⚠ age ticks EVERY waiting cycle → without K scaling,\narbiter degenerates to oldest-first (loses CAS-first).\nK = weights-pass knob.","originalText":"⚠ age ticks EVERY waiting cycle → without K scaling,\narbiter degenerates to oldest-first (loses CAS-first).\nK = weights-pass knob.","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#b91c1c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200092,"version":1,"versionNonce":200093,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"caveat","lineHeight":1.25},


    {"type":"text","id":"nbanks_note","x":480,"y":582,"width":540,"height":40,"text":"bank 0…N−1: each runs the FSM above — own row-lock, own age[] counters.\narbiter merges + applies cross-bank tCCD_L / tRRD_L / tFAW / DQ.","originalText":"bank 0…N−1: each runs the FSM above — own row-lock, own age[] counters.\narbiter merges + applies cross-bank tCCD_L / tRRD_L / tFAW / DQ.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200080,"version":1,"versionNonce":200081,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.25},

    {"type":"text","id":"age_rule","x":110,"y":890,"width":400,"height":40,"text":"age[lane] += 1 every waiting cycle · reset 0 on win\n→ starved lane climbs until it preempts (bounded starvation).","originalText":"age[lane] += 1 every waiting cycle · reset 0 on win\n→ starved lane climbs until it preempts (bounded starvation).","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#3b82f6","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200082,"version":1,"versionNonce":200083,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.25},


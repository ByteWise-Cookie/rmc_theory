    {"type":"text","id":"evid_t","x":1088,"y":592,"width":280,"height":216,"text":"LATENCY  (tCK, b4800)\n────────────────────\nrow-hit  best  : CAS → RL 40\nrow-empty      : tRCD+RL\n               = 39+40 = 79\nrow-miss worst : PRE+ACT+CAS\n               = 39+39+40 = 118\n               + BL/2 8  = 126\n+ refresh      : + tRFC 708\nwrite tail→PRE : WL+BL2+tWR\n               = 38+8+72 = 118","originalText":"LATENCY  (tCK, b4800)\n────────────────────\nrow-hit  best  : CAS → RL 40\nrow-empty      : tRCD+RL\n               = 39+40 = 79\nrow-miss worst : PRE+ACT+CAS\n               = 39+39+40 = 118\n               + BL/2 8  = 126\n+ refresh      : + tRFC 708\nwrite tail→PRE : WL+BL2+tWR\n               = 38+8+72 = 118","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200102,"version":1,"versionNonce":200103,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"evid","lineHeight":1.4}
